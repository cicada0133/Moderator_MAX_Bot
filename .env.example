BOT_TOKEN=put_your_max_bot_token_here
MAX_API_BASE_URL=https://platform-api2.max.ru

# For the first live check you can set DRY_RUN=true.
# The bot will log what it would delete, but will not call DELETE /messages.
DRY_RUN=false

# Send a short bot message after moderation.
MODERATION_NOTIFY=true
MODERATION_WARNING={user}, ваше сообщение удалено: в чате запрещена ненормативная лексика. Давайте жить дружно 🙂

# Send moderation details to bot admins in direct messages.
# The log includes chat_id, message_id, user_id, matched token, rule and original text.
ADMIN_LOG_ENABLED=false
ADMIN_LOG_NOTIFY=false
ADMIN_LOG_TEXT_LIMIT=1200

# Extra comma-separated words or fragments, normalized before matching.
# Example: CUSTOM_BAD_WORDS=оскорбление1,оскорбление2
CUSTOM_BAD_WORDS=

# Exact words that should never be blocked after normalization.
# Example: ALLOW_WORDS=слово1,слово2
ALLOW_WORDS=

# User IDs allowed to edit the runtime dictionary with bot commands.
# Send /id to the bot, then put the returned number here.
# Example: BOT_ADMIN_IDS=123456789,987654321
BOT_ADMIN_IDS=
CUSTOM_DICTIONARY_PATH=data/custom-dictionary.json
CUSTOM_ADMINS_PATH=data/admins.json
CUSTOM_SANCTIONS_PATH=data/sanctions.sqlite

# Auto soft-ban after repeated moderation hits in the same group.
# Disabled by default; admins can enable and tune per group with /autoban.
# Rule below means: 3 deleted profanity messages in 10 minutes -> soft-ban for 30 minutes.
AUTO_BAN_ENABLED=false
AUTO_BAN_THRESHOLD=3
AUTO_BAN_WINDOW_MINUTES=10
AUTO_BAN_DURATION_MINUTES=30

# Long polling is for development/testing. Production should use webhook.
POLLING_TIMEOUT_SEC=60
POLLING_LIMIT=100
PROCESS_INITIAL_UPDATES=false

# Webhook server. In production put it behind HTTPS on public port 443.
WEBHOOK_PORT=3000
WEBHOOK_PATH=/max/webhook
WEBHOOK_PUBLIC_URL=https://your-domain.ru/max/webhook
WEBHOOK_SECRET=change_me_12345
