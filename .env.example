BOT_TOKEN=put_your_max_bot_token_here
MAX_API_BASE_URL=https://platform-api2.max.ru

# For the first live check you can set DRY_RUN=true.
# The bot will log what it would delete, but will not call DELETE /messages.
DRY_RUN=false

# Send a short bot message after deletion. Usually better to keep false.
MODERATION_NOTIFY=false
MODERATION_WARNING=Сообщение удалено: в чате запрещён мат.

# Extra comma-separated words or fragments, normalized before matching.
# Example: CUSTOM_BAD_WORDS=оскорбление1,оскорбление2
CUSTOM_BAD_WORDS=

# Exact words that should never be blocked after normalization.
# Example: ALLOW_WORDS=слово1,слово2
ALLOW_WORDS=

# Long polling is for development/testing. Production should use webhook.
POLLING_TIMEOUT_SEC=60
POLLING_LIMIT=100
PROCESS_INITIAL_UPDATES=false

# Webhook server. In production put it behind HTTPS on public port 443.
WEBHOOK_PORT=3000
WEBHOOK_PATH=/max/webhook
WEBHOOK_PUBLIC_URL=https://your-domain.ru/max/webhook
WEBHOOK_SECRET=change_me_12345
